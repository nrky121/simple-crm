{
  "name": "simple-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postbuild": "[ -z \"$DATABASE_URL\" ] || prisma migrate deploy",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
